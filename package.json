{
  "name": "@adobedjangir/commerce-admin-ims-access",
  "version": "1.0.9",
  "description": "Email-based RBAC add-on for @adobedjangir/commerce-admin-management. Assign admin/editor/viewer roles by email via a UI (super-admins in .env), with server-side enforcement of config saves, schema edits, audit reverts, and snapshot ops.",
  "license": "Apache-2.0",
  "author": "Adobe Inc.",
  "keywords": [
    "adobe-io",
    "aio",
    "app-builder",
    "commerce-admin",
    "rbac",
    "ims",
    "access-control"
  ],
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./hook": {
      "types": "./src/hook.d.ts",
      "default": "./src/hook.js"
    },
    "./web": "./web/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/build-web.js",
    "prepare": "npm run build",
    "postinstall": "node -e \"const cp=require('child_process'),fs=require('fs');if(fs.existsSync('./scripts/setup.js'))cp.spawnSync(process.execPath,['./scripts/setup.js'],{stdio:'inherit'});try{require('@adobedjangir/commerce-admin-management/scripts/discover').run()}catch(e){}\""
  },
  "files": [
    "src",
    "actions",
    "web",
    "scripts",
    "README.md",
    "!**/*.ts",
    "!**/*.tsx",
    "!tsconfig.json",
    "**/*.d.ts",
    "!scripts/**/*.d.ts"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@adobedjangir/abdb": "^1.0.0",
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "@types/node": "^20.0.0"
  },
  "peerDependencies": {
    "@adobedjangir/commerce-admin-management": ">=1.0.0"
  },
  "commerceAdmin": {
    "register": "registerImsAccess"
  }
}
